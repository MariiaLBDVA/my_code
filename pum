        n_Fe3_tot = n_H_free
        n_Fe2_left = n_Fe2_tot - n_Fe3_tot #неокисленное железо
    
    # 1.4 Окисленное железо осаждается в скородит
    if n_AsO4_ars > n_Fe3_tot:
        n_Fe3_FeAsO4 = 1 * n_Fe3_tot
        n_As_left = n_AsO4_ars - n_Fe3_FeAsO4
